{% extends 'base.html.twig' %}

{% block title %}Sous catégorie{% endblock %}

{% block body %}
    <div class="container mt-5">
        <div class="form col-md-6 m-auto">
            <h1 class="h2 mb-3 font-weight-normal text-center">Sous catégorie</h1>

            <table class="table table-striped mb-3">
                <tbody>
                    <tr>
                        <th>Id</th>
                        <td>{{ sub_category.id }}</td>
                    </tr>
                    <tr>
                        <th>Sous catégorie</th>
                        <td>{{ sub_category.name }}</td>
                    </tr>
                    <tr>
                        <th>Catégorie</th>
                        <td>{{ sub_category.category.name }}</td>
                    </tr>
                </tbody>
            </table>
            <div class="d-flex align-items-center gap-3 mt-4">
                <a class="btn btn-secondary" href="{{ path('app_sub_category_index') }}">Retour à la liste</a>

                <a class="btn btn-primary" href="{{ path('app_sub_category_edit', {'id': sub_category.id}) }}">Modifier</a>

                {{ include('sub_category/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}
